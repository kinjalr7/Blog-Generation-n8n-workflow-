        "subject": "=Blog  title :{{ $('Parse AI output').item.json.title }}",
        "message": "=<!DOCTYPE html>\n<html>\n<head>\n  <meta charset=\"UTF-8\">\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n  <style>\n    * { margin: 0; padding: 0; box-sizing: border-box; }\n    body { \n      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, sans-serif; \n      max-width: 800px; margin: 0 auto; padding: 40px 20px; background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); min-height: 100vh; \n    }\n    .container { background: rgba(255,255,255,0.95); backdrop-filter: blur(20px); border-radius: 24px; box-shadow: 0 25px 50px rgba(0,0,0,0.25); overflow: hidden; }\n    .header { background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%); padding: 40px 30px; text-align: center; color: white; }\n    .header h1 { font-size: 2.2em; font-weight: 800; margin-bottom: 10px; text-shadow: 0 4px 12px rgba(0,0,0,0.3); }\n    .header p { opacity: 0.95; font-size: 1.1em; }\n    .content { padding: 40px 30px; }\n    .blog-title { font-size: 2em; background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; margin-bottom: 30px; }\n    .seo-metrics { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 20px; margin: 40px 0; }\n    .metric-card { background: linear-gradient(145deg, #ffffff 0%, #f0f0f0 100%); padding: 25px; border-radius: 20px; text-align: center; box-shadow: 0 10px 30px rgba(0,0,0,0.1); transition: transform 0.3s ease; }\n    .metric-card:hover { transform: translateY(-5px); }\n    .metric-icon { font-size: 2.5em; margin-bottom: 15px; }\n    .metric-value { font-size: 1.4em; font-weight: 700; color: #1a1a1a; }\n    .metric-label { color: #64748b; font-size: 0.95em; }\n    .article-section { background: linear-gradient(145deg, #f8fafc 0%, #e2e8f0 100%); padding: 35px; border-radius: 20px; margin: 40px 0; box-shadow: 0 15px 35px rgba(0,0,0,0.08); }\n    .article-title { color: #1e293b; margin-bottom: 25px; font-size: 1.6em; }\n    .article-content { font-size: 16px; line-height: 1.8; color: #334155; }\n    .social-section { display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 25px; margin: 40px 0; }\n    .social-card { background: linear-gradient(135deg, #667eea 0%, #764ba2 50%, #f093fb 100%); padding: 30px; border-radius: 20px; color: white; }\n    .social-card h4 { margin-bottom: 20px; font-size: 1.3em; }\n    .social-card p { line-height: 1.7; opacity: 0.95; }\n    .suggestions { background: linear-gradient(90deg, #10b981 0%, #059669 100%); color: white; padding: 30px; border-radius: 20px; margin: 40px 0; }\n    .suggestions h4 { margin-bottom: 20px; }\n    .footer { background: linear-gradient(135deg, #1e293b 0%, #334155 100%); color: white; padding: 30px; text-align: center; border-radius: 20px; margin-top: 40px; }\n    .footer small { opacity: 0.8; }\n    @media (max-width: 600px) { .content { padding: 25px 20px; } .blog-title { font-size: 1.6em; } }\n  </style>\n</head>\n<body>\n\n  <div class=\"container\">\n    \n    <!-- Header -->\n    <div class=\"header\">\n      <h1>🚀 Blog Draft Approved!</h1>\n      <p>AI‑Generated Content Pipeline • Ready for Publishing</p>\n    </div>\n    \n    <!-- Content -->\n    <div class=\"content\">\n      \n      <!-- Blog Title -->\n      <h2 class=\"blog-title\">{{ $('Parse AI output').item.json.seo_title }}</h2>\n      \n      <!-- SEO Metrics Cards -->\n      <div class=\"seo-metrics\">\n        <div class=\"metric-card\">\n          <div class=\"metric-icon\">🔑</div>\n          <div class=\"metric-value\">{{ $('Parse AI output').item.json.focus_keyword }}</div>\n          <div class=\"metric-label\">Focus Keyword</div>\n        </div>\n        <div class=\"metric-card\">\n          <div class=\"metric-icon\">📍</div>\n          <div class=\"metric-value\">/{{ $('Parse AI output').item.json.url_slug }}</div>\n          <div class=\"metric-label\">URL Slug</div>\n        </div>\n        <div class=\"metric-card\">\n          <div class=\"metric-icon\">📊</div>\n          <div class=\"metric-value\">{{ $('Parse AI output').item.json.lsi_keywords }}</div>\n          <div class=\"metric-label\">LSI Keywords</div>\n        </div>\n        <div class=\"metric-card\">\n          <div class=\"metric-icon\">⭐</div>\n          <div class=\"metric-value\">{{ $('Parse AI output').item.json.readability }}</div>\n          <div class=\"metric-label\">Readability</div>\n        </div>\n      </div>\n      \n      <!-- Full Article -->\n      <div class=\"article-section\">\n        <h3 class=\"article-title\">📝 Complete Blog Article</h3>\n        <div class=\"article-content\">\n          {{ $('Parse AI output').item.json.blog }}\n        </div>\n      </div>\n      \n      <!-- Social Media -->\n      <div class=\"social-section\">\n        <div class=\"social-card\">\n          <h4>💼 LinkedIn Post</h4>\n          <p>{{ $('Parse AI output').item.json.linkedin }}</p>\n        </div>\n        <div class=\"social-card\">\n          <h4>🐦 Twitter/X Thread</h4>\n          <p>{{ $('Parse AI output').item.json.twitter }}</p>\n        </div>\n      </div>\n      \n      <!-- SEO Suggestions -->\n      <div class=\"suggestions\">\n        <h4>💡 SEO Improvement Suggestions</h4>\n        <p>{{ $('Parse AI output').item.json.seo_suggestions }}</p>\n      </div>\n      \n    </div>\n    \n    <!-- Footer -->\n    <div class=\"footer\">\n      <p><strong>Generated:</strong> {{ $('Parse AI output').item.json.generatedAt }} | \n         <strong>Tone:</strong> {{ $('Parse AI output').item.json.tone }}</p>\n      <small>🤖 AI‑Powered Content Pipeline | n8n + Groq</small>\n    </div>\n    \n  </div>\n\n</body>\n</html>",
