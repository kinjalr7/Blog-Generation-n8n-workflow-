      "parameters": {
        "jsCode": "const item = $input.first().json;\n\nconst fileContent = `BLOG TITLE: ${item.title}\nGENERATED: ${item.generatedAt}\nTONE: ${item.tone} | LANGUAGE: ${item.language}\n\n================================================\nFULL BLOG ARTICLE\n================================================\n${item.blog}\n\n================================================\nLINKEDIN POST\n================================================\n${item.linkedin}\n\n================================================\nTWITTER THREAD\n================================================\n${item.twitter}\n\n================================================\nINSTAGRAM CAPTION\n================================================\n${item.instagram}`;\n\nreturn [{\n  json: item,\n  binary: {\n    data: await this.helpers.prepareBinaryData(\n      Buffer.from(fileContent, 'utf-8'),\n      `${item.title}_${new Date().toISOString().slice(0,10)}.txt`,\n      'text/plain'\n    )\n  }\n}];"
      },
