      "parameters": {
        "jsCode": "// Get Blog Agent output (before SEO)\nconst blogRaw = $('Blog & Social Media Generator').item.json.output;\n\n// Get SEO Agent output  \nconst seoRaw = $('SEO Expert').item.json.output;\n\n// Clean Blog output (remove code fences, extra text)\nconst blogClean = blogRaw\n  .replace(/```json/gi, '')\n  .replace(/```/g, '')\n  .replace(/^{/, '{ \"parsed\": true, ')  // Add wrapper if malformed\n  .replace(/}$/, ' }')\n  .trim();\n\n// Try parsing Blog JSON (with fallback)\nlet blogData;\ntry {\n  blogData = JSON.parse(blogClean);\n} catch (e) {\n  // Fallback: extract title/blog manually if JSON broken\n  blogData = {\n    title: \"Untitled Blog\",\n    blog: blogRaw.slice(0, 2000) + \"...\",\n    linkedin: \"LinkedIn post unavailable\",\n    twitter: \"Twitter unavailable\",\n    instagram: \"Instagram unavailable\"\n  };\n}\n\n// Clean & parse SEO JSON\nconst seoClean = seoRaw\n  .replace(/```json/gi, '')\n  .replace(/```/g, '')\n  .trim();\n\nlet seoData;\ntry {\n  seoData = JSON.parse(seoClean);\n} catch (e) {\n  seoData = {\n    seo_title: \"SEO Title N/A\",\n    meta_description: \"Meta description N/A\",\n    focus_keyword: \"N/A\",\n    url_slug: \"untitled\",\n    lsi_keywords: [],\n    readability_score: \"N/A\",\n    seo_suggestions: [\"Check JSON format\"]\n  };\n}\n\n// Form data (clean field names)\nconst formData = $('On form submission').item.json;\n\nreturn [{\n  json: {\n    // Blog content\n    title: blogData.title || formData[' Blog title'] || \"Untitled\",\n    blog: blogData.blog || \"Blog content unavailable\",\n    linkedin: blogData.linkedin || \"\",\n    twitter: Array.isArray(blogData.twitter) \n      ? blogData.twitter.join('\\n\\n') \n      : blogData.twitter || \"\",\n    instagram: blogData.instagram || \"\",\n    \n    // SEO data\n    seo_title: seoData.seo_title || \"\",\n    meta_description: seoData.meta_description || \"\",\n    focus_keyword: seoData.focus_keyword || \"\",\n    url_slug: seoData.url_slug || \"\",\n    lsi_keywords: Array.isArray(seoData.lsi_keywords) \n      ? seoData.lsi_keywords.join(', ') \n      : \"\",\n    readability: seoData.readability_score || \"N/A\",\n    seo_suggestions: Array.isArray(seoData.seo_suggestions)\n      ? seoData.seo_suggestions.join(' | ')\n      : \"\",\n    \n    // Metadata\n    tone: formData.Tone || \"\",\n    language: formData['Language '] || \"\",\n    blog_length: formData['Blog Length '] || \"\",\n    generatedAt: new Date().toISOString()\n  }\n}];"
      },
